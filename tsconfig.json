{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "files": [],
  "references": [
    { "path": "packages/pi-panels" },
    { "path": "packages/pi-mouse" },
    { "path": "packages/pi-linear" },
    { "path": "packages/pi-extra-context" },
    { "path": "packages/pi-read-summary" },
    { "path": "packages/pi-forcefeed" },
    { "path": "packages/pi-exa" }
  ],
  "exclude": ["node_modules", "dist"]
}
