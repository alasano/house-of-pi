{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "include-component-in-tag": true,
  "bump-minor-pre-major": true,
  "pull-request-title-pattern": "chore(release): release${component} ${version}",
  "pull-request-header": "🏠 of π release",
  "pull-request-footer": "[house-of-pi](https://github.com/alasano/house-of-pi)",
  "separate-pull-requests": true,
  "changelog-sections": [
    {
      "type": "feat",
      "section": "Features"
    },
    {
      "type": "fix",
      "section": "Bug Fixes"
    },
    {
      "type": "perf",
      "section": "Performance"
    },
    {
      "type": "deps",
      "section": "Dependencies"
    },
    {
      "type": "refactor",
      "section": "Refactoring"
    },
    {
      "type": "docs",
      "section": "Documentation"
    },
    {
      "type": "test",
      "section": "Tests",
      "hidden": true
    },
    {
      "type": "chore",
      "section": "Miscellaneous",
      "hidden": true
    },
    {
      "type": "build",
      "section": "Build",
      "hidden": true
    },
    {
      "type": "ci",
      "section": "CI",
      "hidden": true
    },
    {
      "type": "style",
      "section": "Styles",
      "hidden": true
    },
    {
      "type": "ops",
      "section": "Operations",
      "hidden": true
    }
  ],
  "packages": {
    "packages/pi-panels": {},
    "packages/pi-mouse": {},
    "packages/pi-linear": {},
    "packages/pi-extra-context": {},
    "packages/pi-forcefeed": {},
    "packages/pi-exa": {}
  }
}
